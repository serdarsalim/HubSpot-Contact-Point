# Chrome Web Store publishing credentials for publish-webstore.sh.
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
#
# CLIENT_ID / CLIENT_SECRET: from a Desktop-app OAuth client in Google Cloud
#   Console, with the Chrome Web Store API enabled.
# REFRESH_TOKEN: generated once for that client with scope
#   https://www.googleapis.com/auth/chromewebstore
# ITEM_ID: the extension id from the Web Store dashboard URL.

CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
ITEM_ID=
