{
  "manifest_version": 3,
  "name": "HubSpot WhatsApp Contacts",
  "version": "2.0.0",
  "description": "Popup list of HubSpot contacts with WhatsApp-ready phone links.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "HubSpot WhatsApp Contacts"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.hubspot.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
